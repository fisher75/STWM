*.onnx
*.npz
*.npy

archives/
assets/
artifacts/
baselines/
data/
figures/
models/checkpoints/
outputs/

# ------------------------------
# Reports policy
#
# Git should keep only compact final evidence:
#   - reports/final/**
#   - small *summary*.json / *decision*.json / *bootstrap*.json / *status*.json
#   - markdown docs if intentionally placed under reports
#
# Git should not keep raw experiment outputs, item rows, per-run JSON,
# candidate payloads, feature dumps, dataset exports, or cache manifests.
# Already tracked files remain tracked until explicitly git-rm --cached.
# ------------------------------
reports/**
!reports/
!reports/**/
!reports/final/**
!reports/**/*.md
!reports/**/*summary*.json
!reports/**/*decision*.json
!reports/**/*bootstrap*.json
!reports/**/*status*.json
!reports/**/*audit*.json

reports/raw/**
reports/runs/**
reports/**/raw/**
reports/**/runs/**
reports/**/*_runs/**
reports/**/*runs/**
reports/**/*_item_rows*.json
reports/**/*_item_scores*.json
reports/**/*_item_manifest*.json
reports/**/*_payload*.json
reports/**/*_features*.json
reports/**/*_feature*.json
reports/**/*_dataset*.json
reports/**/*_export_*.json
reports/**/*_cache*.json
reports/**/*cache*.json
reports/**/*.jsonl

# Historical large report files known to be raw payloads/datasets.
reports/stwm_external_candidate_scoring_v*_export_*.json
reports/stwm_external_hardcase_candidate_expanded_manifest_v2_20260428.json
reports/stwm_external_hardcase_semantic_state_manifest_v1_20260428.json
reports/stwm_semantic_state_measurement_alignment_dataset_v1_20260428.json
reports/stwm_semantic_state_measurement_alignment_dataset_v7_20260428.json
reports/stwm_semantic_state_alignment_v6_score_table_20260428.json
reports/stwm_semantic_state_alignment_v7_score_table_20260428.json
reports/stwm_external_candidate_frozen_measurement_features_v7_20260428.json
reports/stwm_semantic_state_alignment_v6_pointwise_aux/

# ------------------------------
# Manifests policy
#
# Keep protocol/schema/checksum/example/mini manifests in Git.
# Do not keep full train/val/test split manifests or dense item manifests.
# Already tracked files remain tracked until explicitly git-rm --cached.
# ------------------------------
manifests/**
!manifests/
!manifests/**/
!manifests/**/*.md
!manifests/**/README*
!manifests/**/*protocol*.json
!manifests/**/*schema*.json
!manifests/**/*checksum*.json
!manifests/**/*example*.json
!manifests/**/*mini*.json
!manifests/minisplits/**

manifests/**/train*.json
manifests/**/val*.json
manifests/**/test*.json
manifests/**/*_train_*.json
manifests/**/*_val_*.json
manifests/**/*_test_*.json
manifests/**/*item*.json
manifests/**/*dense*.json
manifests/**/*cache*.json

# Lightweight experiment summaries/tables
!outputs/**/comparison*.json
!outputs/**/comparison*.md
!outputs/**/mini_val_summary*.json
!outputs/**/rescue_train_summary.json
!outputs/**/smoke_summary.json
!outputs/**/run_report.json
!outputs/**/config_snapshot.json
!outputs/**/*figure_manifest*.json

# Curated paper figure set
!outputs/visualizations/stwm_v4_2_final_paper_figures/**

# ------------------------------
# third_party: keep source, drop heavy internals
# ------------------------------
third_party/**/__pycache__/
third_party/**/.pytest_cache/
third_party/**/.mypy_cache/
third_party/**/.ruff_cache/
third_party/**/.cache/

third_party/**/build/
third_party/**/dist/
third_party/**/logs/
third_party/**/tmp/
third_party/**/outputs/
third_party/**/results/
third_party/**/runs/
third_party/**/wandb/
third_party/**/checkpoints/
third_party/**/weights/

third_party/**/*.pt
third_party/**/*.pth
third_party/**/*.ckpt
third_party/**/*.safetensors
third_party/**/*.onnx
third_party/**/*.zip
third_party/**/*.tar
third_party/**/*.tar.gz
